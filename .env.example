# PostgreSQL connection (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/drbahrian?sslmode=require"

# JWT secret — generate with: openssl rand -hex 32
ADMIN_JWT_SECRET="change_this_to_a_random_64_char_hex_string"

# Token expiry
ADMIN_TOKEN_EXPIRY_DAYS=7

# App URL (used for absolute URLs in emails/messages)
NEXT_PUBLIC_APP_URL="https://drbahrian.vercel.app"
